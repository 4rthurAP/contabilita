# ── Database ──────────────────────────────────
MONGODB_URI=mongodb://localhost:27017,localhost:27018,localhost:27019/contabilita?replicaSet=rs0
MONGODB_DB_NAME=contabilita

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── App ───────────────────────────────────────
API_PORT=3000
API_PREFIX=api
NODE_ENV=development

# ── Frontend ──────────────────────────────────
VITE_API_URL=http://localhost:3000/api
