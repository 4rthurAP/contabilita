# ── Database ──────────────────────────────────
MONGODB_URI=mongodb://localhost:27017,localhost:27018,localhost:27019/contabilita?replicaSet=rs0
MONGODB_DB_NAME=contabilita

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── App ───────────────────────────────────────
API_PORT=3000
API_PREFIX=api
NODE_ENV=development

# ── Certificate Encryption ────────────────────
CERTIFICATE_ENCRYPTION_KEY=change-me-to-a-64-char-hex-string-for-aes-256

# ── Google OAuth ──────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── SMTP (Email) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Contabilita <noreply@contabilita.com.br>

# ── Frontend ──────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
FRONTEND_URL=http://localhost:5173
